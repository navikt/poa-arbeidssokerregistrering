{
    "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": {
                    "level": "on"
                }
            }
        }
    },
    "formatter": {
        "enabled": true,
        "lineWidth": 120,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "jsxQuoteStyle": "double",
            "trailingCommas": "all"
        }
    },
    "css": {
        "parser": {
            "cssModules": true,
            "tailwindDirectives": true
        },
        "formatter": {
            "enabled": true
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "correctness": {
                "noUnusedImports": "warn",
                "noUnusedVariables": "warn"
            }
        }
    },
    "files": {
        "includes": [
            "**",
            "!.next",
            "!out",
            "!build",
            "!next-env.d.ts",
            "!test-results",
            "!playwright-report",
            "!storybook-static",
            "!public/mockServiceWorker.js"
        ]
    }
}
