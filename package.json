{
    "name": "poa-arbeidssokerregistrering",
    "private": true,
    "packageManager": "pnpm@10.33.4",
    "scripts": {
        "dev": "next dev --webpack | pino-pretty",
        "build": "next build --webpack",
        "start": "next start",
        "lint": "eslint",
        "test": "pnpm lint && vitest",
        "test:ci": "pnpm lint && vitest run",
        "test:e2e": "playwright test",
        "test:e2e:ci": "playwright test --reporter=line",
        "test:e2e:install": "playwright install chromium",
        "prettier": "prettier --write 'src/**/*.ts' 'src/**/*.tsx' 'src/**/*.css'",
        "refresh": "rm -rf node_modules && rm pnpm-lock.yaml && pnpm i --ignore-scripts",
        "prepare": "husky",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build"
    },
    "dependencies": {
        "@alheimsins/virkedager": "2.2.0",
        "@grafana/faro-web-sdk": "2.7.0",
        "@navikt/aksel-icons": "8.10.6",
        "@navikt/arbeidssokerregisteret-utils": "2.1.0",
        "@navikt/ds-css": "8.10.6",
        "@navikt/ds-react": "8.10.6",
        "@navikt/ds-tailwind": "8.10.6",
        "@navikt/nav-dekoratoren-moduler": "4.1.1",
        "@navikt/next-logger": "5.0.0",
        "@navikt/oasis": "4.1.4",
        "@unleash/nextjs": "1.6.4",
        "csp-header": "6.3.1",
        "html-react-parser": "6.1.1",
        "jose": "6.2.3",
        "lodash": "4.18.1",
        "nanoid": "5.1.11",
        "next": "16.2.6",
        "pino": "10.3.1",
        "react": "19.2.6",
        "react-autosuggest": "10.1.0",
        "react-dom": "19.2.6",
        "swr": "2.4.1"
    },
    "devDependencies": {
        "@playwright/test": "1.60.0",
        "@storybook/addon-a11y": "10.4.0",
        "@storybook/nextjs": "10.4.0",
        "@tailwindcss/postcss": "4.3.0",
        "@testing-library/jest-dom": "6.9.1",
        "@types/lodash": "4.17.24",
        "@types/node": "25.9.1",
        "@types/react": "19.2.15",
        "@vitejs/plugin-react": "5.2.0",
        "eslint": "9.39.2",
        "eslint-config-next": "16.2.6",
        "husky": "9.1.7",
        "knip": "6.14.1",
        "lint-staged": "17.0.5",
        "msw": "2.14.6",
        "msw-storybook-addon": "2.0.7",
        "pino-pretty": "13.1.3",
        "postcss": "8.5.15",
        "prettier": "3.8.3",
        "storybook": "10.4.0",
        "tailwindcss": "4.3.0",
        "typescript": "6.0.3",
        "vitest": "4.1.7"
    },
    "engines": {
        "node": ">=24.15.0"
    },
    "prettier": {
        "printWidth": 120,
        "singleQuote": true,
        "tabWidth": 4
    },
    "lint-staged": {
        "*.{js,jsx,json,md,ts,tsx}": "prettier --write"
    },
    "msw": {
        "workerDirectory": [
            "public"
        ]
    },
    "pnpm": {
        "overrides": {
            "vite": "7.3.3",
            "postcss": "8.5.15",
            "ip-address": "10.2.0"
        }
    }
}
