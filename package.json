{
    "name": "poa-arbeidssokerregistrering",
    "private": true,
    "packageManager": "pnpm@11.9.0",
    "scripts": {
        "dev": "next dev --webpack | pino-pretty",
        "build": "next build --webpack",
        "start": "next start",
        "lint": "biome check ./src",
        "format": "biome format --write ./src",
        "test": "pnpm lint && vitest",
        "test:ci": "pnpm lint && vitest run",
        "test:e2e": "playwright test",
        "test:e2e:ci": "playwright test --reporter=line",
        "test:e2e:install": "playwright install chromium",
        "refresh": "rm -rf node_modules && rm pnpm-lock.yaml && pnpm i --ignore-scripts",
        "prepare": "husky",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build"
    },
    "dependencies": {
        "@alheimsins/virkedager": "2.2.0",
        "@grafana/faro-web-sdk": "2.8.0",
        "@navikt/aksel-icons": "8.14.0",
        "@navikt/arbeidssokerregisteret-utils": "2.1.0",
        "@navikt/ds-css": "8.14.0",
        "@navikt/ds-react": "8.14.0",
        "@navikt/ds-tailwind": "8.14.0",
        "@navikt/nav-dekoratoren-moduler": "4.2.2",
        "@navikt/next-logger": "5.0.0",
        "@navikt/oasis": "4.1.4",
        "@unleash/nextjs": "1.6.7",
        "csp-header": "6.3.1",
        "html-react-parser": "6.1.3",
        "jose": "6.2.3",
        "lodash": "4.18.1",
        "nanoid": "5.1.16",
        "next": "16.2.9",
        "pino": "10.3.1",
        "react": "19.2.7",
        "react-autosuggest": "10.1.0",
        "react-dom": "19.2.7",
        "swr": "2.4.2"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.1",
        "@playwright/test": "1.61.1",
        "@storybook/addon-a11y": "10.4.6",
        "@storybook/nextjs": "10.4.6",
        "@tailwindcss/postcss": "4.3.1",
        "@testing-library/jest-dom": "6.9.1",
        "@types/lodash": "4.17.24",
        "@types/node": "26.0.1",
        "@types/react": "19.2.17",
        "@vitejs/plugin-react": "6.0.3",
        "husky": "9.1.7",
        "jsdom": "^29.1.1",
        "knip": "6.23.0",
        "lint-staged": "17.0.8",
        "msw": "2.14.6",
        "msw-storybook-addon": "2.0.7",
        "pino-pretty": "13.1.3",
        "postcss": "8.5.16",
        "storybook": "10.4.6",
        "tailwindcss": "4.3.1",
        "typescript": "6.0.3",
        "vite": "8.1.3",
        "vitest": "4.1.9"
    },
    "engines": {
        "node": ">=24.18.0"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,json,css}": "biome check --write --no-errors-on-unmatched"
    },
    "msw": {
        "workerDirectory": [
            "public"
        ]
    }
}
