{
    "name": "poa-arbeidssokerregistrering",
    "private": true,
    "scripts": {
        "dev": "next dev --webpack | pino-pretty",
        "build": "next build --webpack",
        "start": "next start",
        "lint": "eslint",
        "test": "pnpm lint && vitest",
        "test:ci": "pnpm lint && vitest run",
        "test:e2e": "playwright test",
        "test:e2e:ci": "playwright test --reporter=line",
        "test:e2e:install": "playwright install chromium",
        "prettier": "prettier --write 'src/**/*.ts' 'src/**/*.tsx' 'src/**/*.css'",
        "refresh": "rm -rf node_modules && rm pnpm-lock.yaml && pnpm i --ignore-scripts",
        "prepare": "husky"
    },
    "dependencies": {
        "@alheimsins/virkedager": "2.2.0",
        "@grafana/faro-web-sdk": "2.3.1",
        "@navikt/aksel-icons": "8.9.1",
        "@navikt/arbeidssokerregisteret-utils": "2.1.0",
        "@navikt/ds-css": "8.10.1",
        "@navikt/ds-react": "8.10.1",
        "@navikt/ds-tailwind": "8.9.1",
        "@navikt/nav-dekoratoren-moduler": "3.7.1",
        "@navikt/next-logger": "5.0.0",
        "@navikt/oasis": "4.1.4",
        "@unleash/nextjs": "1.6.4",
        "csp-header": "6.3.1",
        "html-react-parser": "6.0.1",
        "jose": "6.2.2",
        "lodash": "4.18.1",
        "nanoid": "5.1.7",
        "next": "16.2.4",
        "pino": "10.3.1",
        "react": "19.2.5",
        "react-autosuggest": "10.1.0",
        "react-dom": "19.2.5",
        "swr": "2.4.1"
    },
    "devDependencies": {
        "@playwright/test": "1.59.1",
        "@tailwindcss/postcss": "4.2.3",
        "@testing-library/jest-dom": "6.9.1",
        "@types/lodash": "4.17.24",
        "@types/node": "25.6.0",
        "@types/react": "19.2.14",
        "@vitejs/plugin-react": "5.2.0",
        "eslint": "9.39.2",
        "eslint-config-next": "16.2.3",
        "husky": "9.1.7",
        "knip": "6.4.1",
        "lint-staged": "16.4.0",
        "msw": "2.13.3",
        "pino-pretty": "13.1.3",
        "postcss": "8.5.10",
        "prettier": "3.8.3",
        "tailwindcss": "4.2.2",
        "typescript": "6.0.2",
        "vitest": "4.1.4"
    },
    "engines": {
        "node": ">=24.13.1"
    },
    "prettier": {
        "printWidth": 120,
        "singleQuote": true,
        "tabWidth": 4
    },
    "lint-staged": {
        "*.{js,jsx,json,md,ts,tsx}": "prettier --write"
    }
}
